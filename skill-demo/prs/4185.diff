+                  type:
+                    - string
+                    - 'null'
+                  description: Name of the Tier 0 steward if assigned. Null in v1.
+                criticalVulnerabilityFlag:
+                  type:
+                    - boolean
+                    - 'null'
+                  description: True if any open advisory has cvss >= 7.0.
+        provenance:
+          type: object
+          properties:
+            repositoryMapping:
+              type:
+                - object
+                - 'null'
