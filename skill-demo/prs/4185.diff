+        name:
+          type: string
+          example: lodash
+        ecosystem:
+          type: string
+          example: npm
+        health:
+          type:
+            - integer
+            - 'null'
+          example: 18
+        impact:
+          type:
+            - integer
+            - 'null'
+          example: 71
+        lifecycle:
+          type:
+            - string
+            - 'null'
+          enum: [active, stable, declining, abandoned, null]
+        maintainerBusFactor:
+          type:
+            - integer
+            - 'null'
+          example: 1
+        openVulns:
+          oneOf:
