+                    additionalProperties:
+                      oneOf:
+                        - $ref: '#/components/schemas/PackageStewardshipSummary'
+                        - type: 'null'
+        '400':
+          description: Validation error.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+        '401':
+          description: Missing or invalid bearer token.
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Error'
+
+  # ── Stewardships ───────────────────────────────────────────────────────────
+
+  /akrites/stewardships/open:
