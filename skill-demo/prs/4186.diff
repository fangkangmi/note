+        signal: controller.signal,
+      })
+      if (response.status === 200) return true
+      if (response.status === 404) return false
+      throw new Error(`Unexpected status ${response.status} for ${path}`)
+    } finally {
+      clearTimeout(timeoutId)
+    }
+  }
