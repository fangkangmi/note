+    const [root, dotGithub] = await Promise.all([
+      check('SECURITY.md'),
+      check('.github/SECURITY.md'),
+    ])
+    return root || dotGithub
+  } catch (err) {
+    log.warn({ url, err }, 'Security file check failed — securityFileEnabled will be null')
